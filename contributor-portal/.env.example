# ──────────────────────────────────────────────────────────
# Humanbased Contributor Portal — Environment Variables
# ──────────────────────────────────────────────────────────
#
# Single shared Supabase project (uxafdddzhgdhsabkwmgw) — both
# contributor portal and developer portal co-live on the same DB.
# Local dev points directly to this DB. Use your own Supabase auth
# account for testing; clean up test data after.
#
# Copy to .env and fill in values.
# Frontend uses .env.local in packages/webapp/
# ──────────────────────────────────────────────────────────

# Supabase — shared instance with developer portal
SUPABASE_URL=https://uxafdddzhgdhsabkwmgw.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Vision Engine (external GPU server, consumed via ML Backend adapter)
VISION_ENGINE_URL=http://47.84.74.124:8001

# Storage
STORAGE_BUCKET=contribution-uploads

# API
API_URL=http://localhost:8000
WEBAPP_URL=http://localhost:3000

# Feature flags
NEXT_PUBLIC_OAUTH_ENABLED=false   # true | false — flipping to true re-enables all OAuth providers
CAMPAIGN_SOURCE=mock         # mock | supabase
ATTEMPT_INDEX_BACKEND=postgres
LINEAGE_BACKEND=staging      # staging | onchain
