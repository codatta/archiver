# Qwen API配置
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# MySQL for submissions & deliver (综合审核 + 交付生成 共用)
DB_HOST=codatta-prod.mysql.polardb.singapore.rds.aliyuncs.com
DB_PORT=3306
DB_USER=XXX
DB_PASSWORD=XXXXX
DB_NAME=cfp_metacore

# 综合审核入口从数据库读取原始提交数据的 SQL（PENDING 待审核记录）
# 要求返回：
#   - submission_id
#   - data_submission（JSON 字符串，或 data_submission ->> '$.data'）
DB_SUBMISSIONS_SQL=select submission_id, data_submission ->> '$.data' as data_submission from cfp_task_submission where frontier_id in ('8114254168500106625') and template_id in ('AIRDROP_CEX_HOT_WALLET_DEPOSIT', 'AIRDROP_CEX_HOT_WALLET_WITHDRAW') and status = 'PENDING' order by submission_id

# 交付 CSV 生成从数据库读取已通过且已评级（4/5 分）记录的 SQL（ADOPT 已采纳记录）
# 要求返回：
#   - submission_id
#   - data_submission（JSON 字符串，或 data_submission ->> '$.data'）
#   - rating（整型，且为 4 或 5）
DB_DELIVER_SQL=select submission_id, data_submission ->> '$.data' as data_submission, result as rating from cfp_task_submission where frontier_id in ('8114254168500106625') and template_id in ('AIRDROP_CEX_HOT_WALLET_DEPOSIT','AIRDROP_CEX_HOT_WALLET_WITHDRAW') and status='ADOPT'




# 交付 CSV 输出目录（可选，默认: output/deliver_results）
# CSV_OUTPUT_DIR=output/deliver_results

# 综合审核结果路径（用于读取 UI 检测到的交易日期，可选，默认: output/main_audit/comprehensive_audit_results.json）
# COMPREHENSIVE_RESULTS_PATH=output/main_audit/comprehensive_audit_results.json
