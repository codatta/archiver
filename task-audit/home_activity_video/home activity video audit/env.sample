# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

# 可选：显式指定 ffmpeg/ffprobe，避免 PATH 未刷新导致找不到命令
# FFMPEG_BIN_DIR=C:/ffmpeg/bin
# FFMPEG_EXE=C:/ffmpeg/bin/ffmpeg.exe
# FFPROBE_EXE=C:/ffmpeg/bin/ffprobe.exe

# 待审核视频列表 SQL（必填），需返回至少：
#   - submission_id
#   - video_path（本地视频绝对路径或可读路径）
# 可选列：
#   - file_size_bytes
#   - task_id（同任务 pHash 15 天窗口；也可用 frontier_id / template_id 作为 task 标识）
#   - gmt_create（推荐，格式: YYYY-MM-DD HH:MM:SS；用于同批次重复时判定最早提交）
DB_PENDING_VIDEOS_SQL=SELECT submission_id, task_id, frontier_id, template_id, user_id, status, data_submission FROM cfp_submission WHERE frontier_id='10398648328300103309' AND user_id='9667939850300106394' AND status='PENDING' ORDER BY submission_id DESC LIMIT {limit} OFFSET {offset}

# 指纹与审核等级回写表（否则 Phase 0 无法在库内查重）
# 表建议包含列：submission_id, task_id, lightweight_hash, phash_hex, audit_grade, cut_count, updated_at
DB_VIDEO_META_TABLE=video_audit_meta

# ----------------------------------------
# Phase 0：video.hash 去重（默认=批次内 + 数据库历史）
# ----------------------------------------
# 可选：指定历史去重查询表；未配置时默认使用 DB_VIDEO_META_TABLE
# DB_HASH_CHECK_TABLE=cfp_task_submission
# 可选：自定义历史去重 SQL（返回任意一行即视为命中）
# 可用占位符：{video_hash} {submission_id} {task_id}
# PHASE0_DB_HASH_EXISTS_SQL=SELECT 1 FROM cfp_task_submission WHERE deleted=0 AND submission_id<>'{submission_id}' AND JSON_UNQUOTE(JSON_EXTRACT(data_submission,'$.data.video.hash'))='{video_hash}' LIMIT 1

# ----------------------------------------
# Phase 2：剪辑点阈值（B 级）
# ----------------------------------------
# 当 cut_count > PHASE2_MAX_CUTS 认为剪辑点过多，返回 B 级
PHASE2_MAX_CUTS=30

# 可选：分页（main.py 在未传 --db-limit 时会读取）
# DB_LIMIT=100
# DB_OFFSET=0

# ----------------------------------------
# 前置抽帧（供 YOLO 审核）
# ----------------------------------------
# 是否启用前置抽帧（1=开启，0=关闭）
PRE_FRAME_ENABLED=1

# 抽帧输出根目录（默认可设为 output/pre_frames）
PRE_FRAME_OUTPUT_DIR=output/pre_frames

# 抽帧频率（FPS）：你当前目标是 15fps
PRE_FRAME_FPS=15

# 压缩尺寸（建议 640）：按长边压缩，短边按比例缩放
PRE_FRAME_MAX_SIDE=640

# 图片格式与质量（jpg 推荐 2-5，值越小质量越高体积越大）
PRE_FRAME_IMAGE_FORMAT=jpg
PRE_FRAME_JPEG_QSCALE=4

# 是否保留纵横比（1=保留，0=强行拉伸到固定宽高）
PRE_FRAME_KEEP_ASPECT=1

# 单视频抽帧上限（防止超长视频爆磁盘；0 表示不限制）
PRE_FRAME_MAX_FRAMES_PER_VIDEO=0

# 产出清单文件名（每个 submission 一个 manifest）
PRE_FRAME_MANIFEST_NAME=manifest.json

# 清理策略：none / ttl / keep_last_n / hybrid
PRE_FRAME_CLEANUP_MODE=hybrid

# TTL 清理：保留最近 N 小时（cleanup_mode=ttl 或 hybrid 时生效）
PRE_FRAME_RETENTION_HOURS=72

# keep_last_n 清理：每个 submission 最多保留最近 N 个抽帧批次目录（hybrid 也生效）
PRE_FRAME_KEEP_LAST_N_BATCHES=2

# 是否将“需长期保留”的批次打包归档（zip）后再删源文件
PRE_FRAME_ARCHIVE_BEFORE_DELETE=1
PRE_FRAME_ARCHIVE_DIR=output/pre_frames_archive

# 归档白名单（逗号分隔）：例如重要任务 ID；空表示不额外白名单
# PRE_FRAME_ARCHIVE_TASK_IDS=task_a,task_b

# ----------------------------------------
# Phase 3：YOLO 画面审核（独立阶段，可开关）
# ----------------------------------------
# 是否启用 YOLO 画面审核（1=开启，0=关闭）
PHASE3_YOLO_ENABLED=1

# 失败映射等级（建议 A，S 级可留给人工/更高阶模型）
PHASE3_YOLO_FAIL_GRADE=A

# 通用置信度阈值（你当前要求全部 > 0.6，改这个最便捷）
PHASE3_MIN_CONFIDENCE=0.60

# 风险阈值：risk_score >= 阈值判定为 fail
# 留空时自动按 (1 - PHASE3_MIN_CONFIDENCE) 计算
PHASE3_YOLO_RISK_THRESHOLD=

# AI 阶段评级配置：达标给 S，不达标/Unknown 给 A（人工复核）
PHASE3_PASS_GRADE=S
PHASE3_REVIEW_GRADE=A

# YOLO 结果来源：
# 1) 行内字段 yolo_risk_score（优先）
# 2) 行内字段 yolo_result_json（本地 JSON 文件路径）
# 3) fallback: {PRE_FRAME_OUTPUT_DIR}/{submission_id}/latest_yolo_result.json

# 是否在 Phase 3 内直接调用 YOLO API（1=调用，0=仅读取结果）
PHASE3_YOLO_CALL_API=1

# Vision Engine 地址（labeling-vision-engine-main）
PHASE3_YOLO_API_URL=http://127.0.0.1:8001

# API 调用参数（映射到 /tasks/detect-persons）
PHASE3_YOLO_DETECTOR=pose
PHASE3_YOLO_MODEL=yolov8s.pt
PHASE3_YOLO_OBJECT_CONF_THRESHOLD=0.35

# 单次最多送检多少帧（超出会均匀抽样）
PHASE3_YOLO_API_MAX_FRAMES=120

# Phase3 实时抽帧（直接对当前视频抽样）
PHASE3_REALTIME_SAMPLE_FRAMES=24
# PHASE3_RUNTIME_FRAME_DIR=D:/temp/phase3_runtime_frames

# Phase3 家务场景双指标阈值（用于 pass/fail）
# 留空时默认继承 PHASE3_MIN_CONFIDENCE
PHASE3_HANDS_MIN_CONFIDENCE=
PHASE3_OBJECT_MIN_CONFIDENCE=
# 当从 row 字段（template_id/task_id/task_name）推断视频类型时的置信度
PHASE3_ROW_VIDEO_TYPE_CONFIDENCE=0.95
# 当 YOLO 类型与任务映射类型冲突时，若 YOLO 置信度高于此阈值则进入人工审核
PHASE3_TYPE_MISMATCH_REVIEW_CONFIDENCE=0.80

# Phase3 第三条件：第一人称视角置信度阈值（>= 该值才认为满足）
# 默认 0.6，便于你快速调整
PHASE3_FIRST_PERSON_MIN_CONFIDENCE=0.60
# 第一人称空间规则（支持“下半区”或“上下分布”两种命中模式）
PHASE3_FIRST_PERSON_X_MIN=0.20
PHASE3_FIRST_PERSON_X_MAX=0.80
PHASE3_FIRST_PERSON_Y_LOWER=0.55
PHASE3_FIRST_PERSON_Y_UPPER=0.45
PHASE3_FIRST_PERSON_Y_SPAN=0.22
# 双手区域占比规则（第一人称主判定）
# area_ratio = (max_x-min_x) * (max_y-min_y)
# area_score = min(1, area_ratio / AREA_TARGET)
PHASE3_FIRST_PERSON_AREA_TARGET=0.06
PHASE3_FIRST_PERSON_AREA_MIN=0.025
# 前景占比辅助权重（0~1）：越大越容易给第一视角加分
PHASE3_FIRST_PERSON_FOREGROUND_WEIGHT=0.30
# 时间连续性加分：连续命中窗口长度与最大奖励
PHASE3_FIRST_PERSON_TEMPORAL_WINDOW=5
PHASE3_FIRST_PERSON_TEMPORAL_BONUS_MAX=0.10
# 是否将第一人称作为 S 级硬门槛（1=必须满足，0=不强制；建议 home-cleaning 设 0）
PHASE3_REQUIRE_FIRST_PERSON=0

# 交互稳健化系数：当手和物体“同帧共现”但未明显贴近时，也给一定交互分
# object_interaction_confidence = max(近距离交互占比, 共现占比 * 该系数)
PHASE3_OBJECT_COEXIST_WEIGHT=0.80

# URL 下载缓存目录（仅当视频路径是 http/https 时使用）
# VIDEO_DOWNLOAD_TEMP_DIR=D:/temp

# 每条审核结束后是否删除该 submission 的抽帧目录（强清理，节省磁盘）
# 1=删除 0=保留
POST_AUDIT_DELETE_PRE_FRAMES=0
